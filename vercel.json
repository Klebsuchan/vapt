{
  "version": 2,
  "cleanUrls": true,
  "routes": [
    {
      "src": "/(.*\\.(png|jpg|jpeg|gif|svg|webp|mp4|webm|ogg|mp3|wav|flac|aac))$",
      "headers": {
        "cache-control": "public, max-age=31536000, immutable"
      },
      "continue": true
    },
    {
      "src": "/assets/(.*)",
      "headers": {
        "cache-control": "public, max-age=31536000, immutable"
      },
      "continue": true
    },
    {
      "handle": "filesystem"
    },
    {
      "src": "/(.*)",
      "dest": "/index.html"
    }
  ]
}
